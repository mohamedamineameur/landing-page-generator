{
  "version": "4.0",
  "meta": {
    "name": "Capturia Funnel Builder DSL",
    "description": "AI-driven page builder schema",
    "strict": true
  },
  "rendering": {
    "uiLibrary": {
      "name": "Tailwind CSS",
      "package": "tailwindcss",
      "themeProvider": "css-variables-and-utility-classes",
      "primitivesToken": "tailwindPrimitive"
    },
    "iconLibrary": {
      "name": "Runtime SVG Icons",
      "package": "inline-svg",
      "token": "icon"
    },
    "notes": [
      "All design system primitives are rendered with Tailwind utility classes and CSS variables.",
      "All icon props should use the runtime icon token instead of a framework-specific icon package.",
      "The runtime maps CTA, layout, cards, forms and navigation to React components styled with Tailwind CSS."
    ]
  },
  "tokens": {
    "spacing": ["none", "xs", "sm", "md", "lg", "xl", "2xl", "3xl", "4xl"],
    "radius": ["none", "xs", "sm", "md", "lg", "xl", "2xl", "full"],
    "shadow": ["none", "xs", "sm", "md", "lg", "xl", "2xl"],
    "textAlign": ["left", "center", "right"],
    "layout": ["stack", "grid", "split", "columns", "masonry", "carousel", "tabs"],
    "background": ["transparent", "white", "muted", "primary", "secondary", "dark", "gradient"],
    "ctaAction": [
      "scroll_to_form",
      "scroll_to_section",
      "open_modal",
      "navigate",
      "submit_form",
      "start_quiz",
      "book_call",
      "download",
      "copy_code",
      "play_video"
    ],
    "mediaType": ["image", "video", "animation", "icon", "logo"],
    "aspectRatio": ["1:1", "4:3", "3:2", "16:9", "21:9", "auto"],
    "variantTone": ["neutral", "professional", "friendly", "luxury", "bold", "minimal"],
    "width": ["xs", "sm", "md", "lg", "xl", "2xl", "full"],
    "columns": [1, 2, 3, 4, 5, 6],
    "iconPosition": ["left", "right", "top", "bottom"],
    "formFieldType": [
      "text",
      "email",
      "tel",
      "number",
      "textarea",
      "select",
      "radio",
      "checkbox",
      "date",
      "time",
      "hidden",
      "url"
    ],
    "buttonVariant": ["primary", "secondary", "outline", "ghost", "link"],
    "badgeVariant": ["solid", "soft", "outline"],
    "animationType": ["none", "fade_in", "slide_up", "slide_left", "slide_right", "zoom_in"],
    "deviceVisibility": ["all", "desktop", "tablet", "mobile"],
    "tailwindPrimitive": [
      "div",
      "section",
      "article",
      "nav",
      "header",
      "footer",
      "button",
      "a",
      "img",
      "form",
      "input",
      "textarea",
      "select",
      "table",
