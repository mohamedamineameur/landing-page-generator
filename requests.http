@baseUrl = http://localhost:3000
@username = amine_test
@password = password123
@projectName = Projet demo

### 1) Auth (Supabase)
# Cette app utilise Supabase Auth via cookies SSR.
# Fais l'inscription + login depuis l'UI: {{baseUrl}}/auth
# (username -> email interne {{username}}@capturia.local)

@projectId = colle_ici_l_uuid_du_projet
@pageId = colle_ici_l_uuid_de_la_page

### 2) Creer un projet
POST {{baseUrl}}/api/projects
Content-Type: application/json

{
  "name": "{{projectName}}"
}

### 3) Lister mes projets
GET {{baseUrl}}/api/projects

### 4) Recuperer un projet par id
GET {{baseUrl}}/api/projects/{{projectId}}

### 5) Creer une premiere page effective
POST {{baseUrl}}/api/projects/{{projectId}}/pages
Content-Type: application/json

{
  "payload": {
    "title": "Landing page v1",
    "sections": [
      {
        "type": "hero",
        "headline": "Bienvenue"
      }
    ]
  }
}

### 6) Lister l'historique des pages d'un projet
GET {{baseUrl}}/api/projects/{{projectId}}/pages

### 7) Recuperer une page par id
GET {{baseUrl}}/api/pages/{{pageId}}

### 8) Creer une nouvelle version a partir d'une page existante
PATCH {{baseUrl}}/api/pages/{{pageId}}
Content-Type: application/json

{
  "payload": {
    "title": "Landing page v2",
    "sections": [
      {
        "type": "hero",
        "headline": "Bienvenue sur la version 2"
      }
    ]
  }
}

### 9) Rendre une page precise effective
POST {{baseUrl}}/api/pages/{{pageId}}/effective

### 10) Sessions (liste + révocation)
GET {{baseUrl}}/api/sessions

### 11) Revoquer une session
POST {{baseUrl}}/api/sessions
Content-Type: application/json

{
  "sessionId": "{{sessionId}}"
}
