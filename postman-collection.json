{
  "info": {
    "_postman_id": "d8bcf44c-5a9a-4f5a-b904-1f7f3c8ef001",
    "name": "Capturia Funnel API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "username",
      "value": "amine_test"
    },
    {
      "key": "password",
      "value": "password123"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "projectId",
      "value": ""
    },
    {
      "key": "pageId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/users"
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "List Projects",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/projects"
      }
    },
    {
      "name": "Create Project",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Projet demo\"\n}"
        },
        "url": "{{baseUrl}}/api/projects"
      }
    },
    {
      "name": "Get Project",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/projects/{{projectId}}"
      }
    },
    {
      "name": "Update Project Name",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Projet demo renomme\"\n}"
        },
        "url": "{{baseUrl}}/api/projects/{{projectId}}"
      }
    },
    {
      "name": "Create Page",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payload\": {\n    \"title\": \"Landing page v1\",\n    \"sections\": [\n      {\n        \"type\": \"hero\",\n        \"headline\": \"Bienvenue\"\n      }\n    ]\n  }\n}"
        },
        "url": "{{baseUrl}}/api/projects/{{projectId}}/pages"
      }
    },
    {
      "name": "List Project Pages",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/projects/{{projectId}}/pages"
      }
    },
    {
      "name": "Get Page",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/pages/{{pageId}}"
      }
    },
    {
      "name": "Create Page Version",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payload\": {\n    \"title\": \"Landing page v2\",\n    \"sections\": [\n      {\n        \"type\": \"hero\",\n        \"headline\": \"Bienvenue sur la version 2\"\n      }\n    ]\n  }\n}"
        },
        "url": "{{baseUrl}}/api/pages/{{pageId}}"
      }
    },
    {
      "name": "Set Effective Page",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/pages/{{pageId}}/effective"
      }
    }
  ]
}
